{
  "name": "@santuario-maringa/monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --summarize",
    "dev:api": "turbo run dev --filter=@santuario-maringa/api --summarize",
    "dev:mobile:ios": "turbo run ios --filter=@santuario-maringa/mobile --summarize",
    "dev:mobile:android": "turbo run android --filter=@santuario-maringa/mobile --summarize",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@santuario-maringa/api",
    "build:mobile": "turbo run build --filter=@santuario-maringa/mobile",
    "lint": "oxlint --report-unused-disable-directives",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "turbo": "2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "patchedDependencies": {
    "react-native-css-interop@0.2.4": "patches/react-native-css-interop@0.2.4.patch"
  }
}
