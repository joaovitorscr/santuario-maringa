{
  "expo": {
    "name": "santuario-maringa",
    "slug": "santuario-maringa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "santuario-maringa",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "br.com.santuariomaringa.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "br.com.santuariomaringa.app",
      "adaptiveIcon": {
        "backgroundColor": "#94D7A8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita que o app acesse suas fotos para cadastrar a imagem do residente.",
          "cameraPermission": "Permita que o app use a camera para tirar a foto do residente."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#94D7A8",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-navigation-bar",
        {
          "visibility": "hidden"
        }
      ],
      "expo-sharing",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6d887663-3bc6-4559-b19c-f0f5fcd35213"
      }
    },
    "owner": "joaovitorscr",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6d887663-3bc6-4559-b19c-f0f5fcd35213"
    }
  }
}
